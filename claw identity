                design: { bodyColor: '#C792EA', bodyShape: 'bean', clawColor: '#FFE66D', clawShape: 'blob', tailColor: '#FFB6C1', tailShape: 'stubby', eyeStyle: 'star', patternStyle: 'none', patternColor: '#FFFFFF', diyCanvas: null }
            },
            {
                id: '004', date: '2023-10-27', owner: 'Lily', name: 'Sparkles', relationship: 'Coworker', story: 'Great at debugging.',
                design: { bodyColor: '#FFE66D', bodyShape: 'squat', clawColor: '#FF6B6B', clawShape: 'snipper', tailColor: '#4ECDC4', tailShape: 'spiky', eyeStyle: 'googly', patternStyle: 'stripes', patternColor: '#FFB6C1', diyCanvas: null }
            },
            {
                id: '005', date: '2023-10-28', owner: 'Leo', name: 'Snappy', relationship: 'Nemesis', story: 'Stole my favorite pebble.',
                design: { bodyColor: '#A8E6CF', bodyShape: 'round', clawColor: '#2C3E50', clawShape: 'crab', tailColor: '#A8E6CF', tailShape: 'fan', eyeStyle: 'dot', patternStyle: 'belly', patternColor: '#FFF9F0', diyCanvas: null }
            },
             {
                id: '006', date: '2023-10-29', owner: 'Mia', name: 'Bubbles', relationship: 'Best Friend', story: 'Loves taking bubble baths.',
                design: { bodyColor: '#FFB6C1', bodyShape: 'bean', clawColor: '#C792EA', clawShape: 'mitten', tailColor: '#FFE66D', tailShape: 'mermaid', eyeStyle: 'star', patternStyle: 'polka', patternColor: '#FFFFFF', diyCanvas: null }
            }
        ];

        // --- ICONS (SVG) ---
        const Icons = {
            Draw: () => <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round" className="w-5 h-5"><path d="M12 19l7-7 3 3-7 7-3-3z"></path><path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"></path><path d="M2 2l7.586 7.586"></path><circle cx="11" cy="11" r="2"></circle></svg>,
            Erase: () => <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round" className="w-5 h-5"><path d="M20 20H7L3 16C2.5 15.5 2.5 14.5 3 14L13 4C13.5 3.5 14.5 3.5 15 4L20 9C20.5 9.5 20.5 10.5 20 11L11 20"></path><path d="M16 16L12 12"></path></svg>,
            Download: () => <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round" className="w-6 h-6"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>,
            Home: () => <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round" className="w-6 h-6"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>,
            Gallery: () => <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round" className="w-6 h-6"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg>,
            Seal: () => <svg viewBox="0 0 100 100" className="w-full h-full"><path d="M50 0L56 12L68 8L71 20L84 21L82 34L94 39L88 50L94 61L82 66L84 79L71 80L68 92L56 88L50 100L44 88L32 92L29 80L16 79L18 66L6 61L12 50L6 39L18 34L16 21L29 20L32 8L44 12L50 0Z" fill="#FFE66D" stroke="#2C3E50" strokeWidth="3"/><circle cx="50" cy="50" r="30" fill="none" stroke="#2C3E50" strokeWidth="2" strokeDasharray="4 4"/><text x="50" y="45" font-family="Fredoka" font-size="12" font-weight="bold" fill="#2C3E50" text-anchor="middle">OFFICIALLY</text><text x="50" y="60" font-family="Fredoka" font-size="14" font-weight="bold" fill="#FF6B6B" text-anchor="middle">CUTE</text></svg>
        };

        // --- CRAWFISH SVG RENDERER ---
        const CuteCrawfish = ({ design, className = "", animate = false }) => {
            const s = design;

            // Generators for Paths based on Shape State
            const getBodyPath = (shape) => {
                switch(shape) {
                    case 'bean': return "M 95 200 C 95 130, 155 120, 200 145 C 245 170, 200 260, 155 260 C 110 260, 95 245, 95 200 Z";
                    case 'pear': return "M 150 120 C 185 120, 210 185, 220 235 C 225 270, 75 270, 80 235 C 90 185, 115 120, 150 120 Z";
                    case 'squat': return "M 70 225 C 70 155, 230 155, 230 225 C 230 275, 70 275, 70 225 Z";
                    case 'round': 
                    default: return "M 80 200 C 80 125, 220 125, 220 200 C 220 275, 80 275, 80 200 Z";
                }
            };

            const getTailPath = (shape) => {
                switch(shape) {
                    case 'mermaid': return "M 150 245 C 150 300, 220 360, 240 370 C 200 350, 150 350, 150 380 C 150 350, 100 350, 60 370 C 80 360, 150 300, 150 240 Z";
                    case 'stubby': return "M 110 240 L 190 240 C 200 280, 180 320, 150 320 C 120 320, 100 280, 110 240 Z";
                    case 'spiky': return "M 120 240 L 180 240 L 220 300 L 180 340 L 150 300 L 120 340 L 80 300 Z";
                    case 'fan':
                    default: return "M 120 240 C 150 240, 180 240, 180 240 C 230 320, 240 350, 150 360 C 60 350, 70 320, 120 240 Z";
                }
            };

            const getClawPath = (shape, side) => {
                const mult = side === 'left' ? 1 : -1;
                const ox = side === 'left' ? 0 : 300; // rough offsets for mirror
                
                // We define claw in local space, then transform
                let path = "";
                let cx = 0, cy = 0; // connection point
                
                switch(shape) {
                    case 'crab': path = "M 0 20 C 30 -20, 80 -20, 90 20 L 50 40 L 70 80 C 30 90, -10 60, 0 20 Z M 50 40 L 90 20"; break;
                    case 'snipper': path = "M 10 30 L 70 -10 L 80 10 L 40 40 L 90 60 L 70 80 Z"; break;
                    case 'blob': path = "M 10 40 C 0 -10, 80 -20, 90 30 C 100 80, 30 90, 10 40 Z"; break;
                    case 'mitten':
                    default: path = "M 20 40 C 10 0, 70 -10, 80 30 C 90 70, 70 80, 50 80 C 40 80, 30 90, 20 80 C 10 70, 25 50, 20 40 Z"; break;
                }
                return path;
            };

            const renderEyes = (style) => {
                const drawEye = (cx, cy, r, pr, pdx, pdy, hasCatchlight = true) => (
                    <g>
                        <circle cx={cx} cy={cy} r={r} fill="#FFFFFF" stroke="#2C3E50" strokeWidth="5" />
                        {style === 'star' ? (
                            <path d={`M ${cx} ${cy-pr} L ${cx+pr*0.3} ${cy-pr*0.3} L ${cx+pr} ${cy} L ${cx+pr*0.3} ${cy+pr*0.3} L ${cx} ${cy+pr} L ${cx-pr*0.3} ${cy+pr*0.3} L ${cx-pr} ${cy} L ${cx-pr*0.3} ${cy-pr*0.3} Z`} fill="#2C3E50"/>
                        ) : (
                            <circle cx={cx+pdx} cy={cy+pdy} r={pr} fill="#2C3E50" />
                        )}
                        {hasCatchlight && style !== 'star' && <circle cx={cx+pdx-pr*0.3} cy={cy+pdy-pr*0.3} r={pr*0.3} fill="#FFFFFF" />}
                    </g>
                );

                switch(style) {
                    case 'sleepy':
                        return (
                            <g>
                                <path d="M 100 130 Q 125 100 145 130" fill="#FFFFFF" stroke="#2C3E50" strokeWidth="5" strokeLinecap="round"/>
                                <path d="M 100 130 Q 125 140 145 130" fill="none" stroke="#2C3E50" strokeWidth="5" strokeLinecap="round"/>
                                <path d="M 155 130 Q 180 100 200 130" fill="#FFFFFF" stroke="#2C3E50" strokeWidth="5" strokeLinecap="round"/>
                                <path d="M 155 130 Q 180 140 200 130" fill="none" stroke="#2C3E50" strokeWidth="5" strokeLinecap="round"/>
                            </g>
                        );
                    case 'dot':
                        return (
                            <g>
                                <circle cx="115" cy="130" r="8" fill="#2C3E50" />
                                <circle cx="185" cy="130" r="8" fill="#2C3E50" />
                            </g>
                        );
                    case 'star':
                        return (
                            <g>
                                {drawEye(120, 120, 28, 12, 0, 0, false)}
                                {drawEye(180, 120, 28, 12, 0, 0, false)}
                            </g>
                        );
                    case 'googly':
                    default:
                        return (
                            <g>
                                {/* Left slightly larger and overlapping */}
                                {drawEye(185, 120, 30, 12, -4, 2)}
                                {drawEye(125, 115, 35, 14, 6, 4)} 
                            </g>
                        );
                }
            };

            const renderPattern = () => {
                if (s.patternStyle === 'none') return null;
                const color = s.patternColor;

                if (s.patternStyle === 'polka') {
                    return (
                        <g fill={color} opacity="0.6">
                            <circle cx="100" cy="180" r="15" />
                            <circle cx="150" cy="150" r="10" />
                            <circle cx="200" cy="190" r="18" />
                            <circle cx="140" cy="220" r="25" />
                            <circle cx="90" cy="240" r="12" />
                            <circle cx="210" cy="250" r="14" />
                            <circle cx="180" cy="280" r="10" />
                            <circle cx="120" cy="270" r="16" />
                        </g>
                    );
                }
                if (s.patternStyle === 'stripes') {
                    return (
                        <g stroke={color} strokeWidth="18" strokeLinecap="round" opacity="0.6">
                            <path d="M 50 160 Q 150 180 250 160" />
                            <path d="M 40 200 Q 150 220 260 200" />
                            <path d="M 50 240 Q 150 260 250 240" />
                            <path d="M 70 280 Q 150 300 230 280" />
                        </g>
                    );
                }
                if (s.patternStyle === 'belly') {
                    return (
                        <path d="M 100 180 C 100 130, 200 130, 200 180 C 200 260, 100 260, 100 180 Z" fill={color} opacity="0.8" />
                    );
                }
                return null;
            };

            return (
                <svg viewBox="0 0 300 400" className={`w-full h-full ${className}`}>
                    <g className={animate ? "animate-bounce-center" : ""}>
                        
                        {/* Antennae - Back layer */}
                        <g stroke="#2C3E50" strokeWidth="5" strokeLinecap="round" fill="none">
                            <path d="M 135 115 Q 100 50 120 20" className={animate ? "animate-wiggle" : ""} style={{ transformOrigin: '130px 110px' }} />
                            <path d="M 165 115 Q 200 50 180 20" className={animate ? "animate-wiggle" : ""} style={{ transformOrigin: '170px 110px', animationDelay: '0.2s' }} />
                        </g>

                        {/* Tail - Back layer */}
                        <path d={getTailPath(s.tailShape)} fill={s.tailColor} stroke="#2C3E50" strokeWidth="5" strokeLinejoin="round" />
                        {/* Tail details */}
                        <g stroke="#2C3E50" strokeWidth="4" strokeLinecap="round" opacity="0.3">
                            <line x1="150" y1="260" x2="150" y2="330" />
                            <line x1="130" y1="265" x2="110" y2="310" />
                            <line x1="170" y1="265" x2="190" y2="310" />
                        </g>

                        {/* Arms (Lines connecting body to claws) */}
                        <g stroke="#2C3E50" strokeWidth="12" strokeLinecap="round" fill="none">
                            <path d="M 100 180 Q 40 140 50 80" />
                            <path d="M 200 180 Q 260 140 250 80" />
                        </g>
                        <g stroke={s.clawColor} strokeWidth="6" strokeLinecap="round" fill="none">
                            <path d="M 100 180 Q 40 140 50 80" />
                            <path d="M 200 180 Q 260 140 250 80" />
                        </g>

                        {/* Left Claw */}
                        <g transform="translate(-10, 10) rotate(-20 50 80)">
                            <path d={getClawPath(s.clawShape, 'left')} fill={s.clawColor} stroke="#2C3E50" strokeWidth="5" strokeLinejoin="round" />
                            {/* Claw highlight */}
                            <path d={getClawPath(s.clawShape, 'left')} fill="none" stroke="#FFFFFF" strokeWidth="4" strokeLinecap="round" opacity="0.4" transform="scale(0.8) translate(15, 15)" />
                        </g>

                        {/* Right Claw */}
                        <g transform="translate(190, 10) rotate(20 50 80) scale(-1, 1) translate(-100, 0)">
                             <path d={getClawPath(s.clawShape, 'right')} fill={s.clawColor} stroke="#2C3E50" strokeWidth="5" strokeLinejoin="round" />
                             <path d={getClawPath(s.clawShape, 'right')} fill="none" stroke="#FFFFFF" strokeWidth="4" strokeLinecap="round" opacity="0.4" transform="scale(0.8) translate(15, 15)" />
                        </g>

                        {/* Main Body Layer */}
                        <g>
                            <path id="mainBodyPath" d={getBodyPath(s.bodyShape)} fill={s.bodyColor} stroke="#2C3E50" strokeWidth="5" strokeLinejoin="round" />
                            
                            {/* Clip path for pattern & DIY Canvas to keep them inside the body */}
                            <clipPath id="bodyClip">
                                <path d={getBodyPath(s.bodyShape)} />
                            </clipPath>
                            
                            <g clipPath="url(#bodyClip)">
                                {renderPattern()}
                                
                                {/* DIY Drawing Canvas Overlay */}
                                {s.diyCanvas && (
                                    <image href={s.diyCanvas} x="50" y="100" width="200" height="200" preserveAspectRatio="xMidYMid slice" />
                                )}

                                {/* Body Soft Shadow (Inner) */}
                                <path d={getBodyPath(s.bodyShape)} fill="none" stroke="#000000" strokeWidth="20" opacity="0.1" transform="translate(-5, -5)" />
                                {/* Body Highlight */}
                                <path d={getBodyPath(s.bodyShape)} fill="none" stroke="#FFFFFF" strokeWidth="15" strokeLinecap="round" opacity="0.3" transform="scale(0.85) translate(25, 30)" />
                            </g>
                        </g>

                        {/* Face Details */}
                        {renderEyes(s.eyeStyle)}
                        
                        {/* Blush */}
                        <ellipse cx="105" cy="155" rx="14" ry="8" fill="#FF6B6B" opacity="0.4" transform="rotate(-10 105 155)" />
                        <ellipse cx="195" cy="155" rx="14" ry="8" fill="#FF6B6B" opacity="0.4" transform="rotate(10 195 155)" />
                        
                        {/* Smile */}
                        <path d="M 135 155 Q 150 175 165 155" fill="none" stroke="#2C3E50" strokeWidth="4" strokeLinecap="round" />

                    </g>
                </svg>
            );
        };

        // --- DIY CANVAS COMPONENT ---
        const DIYCanvas = ({ onSave, initialData }) => {
            const canvasRef = useRef(null);
            const [isDrawing, setIsDrawing] = useState(false);
            const [color, setColor] = useState('#2C3E50');
            const [brushSize, setBrushSize] = useState(8);
            const [tool, setTool] = useState('brush'); // brush, eraser

            useEffect(() => {
                const canvas = canvasRef.current;
                const ctx = canvas.getContext('2d');
                
                // Clear and set initial data if any
                ctx.clearRect(0, 0, canvas.width, canvas.height);
                if (initialData) {
                    const img = new Image();
                    img.onload = () => ctx.drawImage(img, 0, 0);
                    img.src = initialData;
                }
            }, [initialData]);

            const startDrawing = (e) => {
                const { offsetX, offsetY } = getCoordinates(e);
                const ctx = canvasRef.current.getContext('2d');
                ctx.beginPath();
                ctx.moveTo(offsetX, offsetY);
                setIsDrawing(true);
            };

            const draw = (e) => {
                if (!isDrawing) return;
                const { offsetX, offsetY } = getCoordinates(e);
                const ctx = canvasRef.current.getContext('2d');
                
                ctx.lineTo(offsetX, offsetY);
                ctx.strokeStyle = tool === 'eraser' ? 'rgba(0,0,0,1)' : color;
                ctx.lineWidth = brushSize;
                ctx.lineCap = 'round';
                ctx.lineJoin = 'round';
                
                if (tool === 'eraser') {
                    ctx.globalCompositeOperation = 'destination-out';
                } else {
                    ctx.globalCompositeOperation = 'source-over';
                }
                
                ctx.stroke();
            };

            const endDrawing = () => {
                if(isDrawing){
                    const ctx = canvasRef.current.getContext('2d');
                    ctx.closePath();
                    setIsDrawing(false);
                    saveCanvas();
                }
            };

            const getCoordinates = (e) => {
                const canvas = canvasRef.current;
                const rect = canvas.getBoundingClientRect();
                
                // Scale mouse coordinates to canvas resolution
                const scaleX = canvas.width / rect.width;
                const scaleY = canvas.height / rect.height;

                if (e.touches && e.touches.length > 0) {
                    return {
                        offsetX: (e.touches[0].clientX - rect.left) * scaleX,
                        offsetY: (e.touches[0].clientY - rect.top) * scaleY
                    };
                }
                return {
                    offsetX: (e.clientX - rect.left) * scaleX,
                    offsetY: (e.clientY - rect.top) * scaleY
                };
            };

            const saveCanvas = () => {
                onSave(canvasRef.current.toDataURL('image/png'));
            };

