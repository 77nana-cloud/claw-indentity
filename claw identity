        };

        const DUMMY_WALL = [
            {
                id: '001', date: '2023-10-24', owner: 'Tommy', name: 'Mr. Pinch', relationship: 'Best Friend', story: 'He likes to pinch my nose.',
                design: { bodyColor: '#FF6B6B', bodyShape: 'round', clawColor: '#4ECDC4', clawShape: 'mitten', tailColor: '#FFE66D', tailShape: 'fan', eyeStyle: 'googly', patternStyle: 'polka', patternColor: '#FFFFFF', diyCanvas: null }
            },
            {
