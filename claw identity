                design: { bodyColor: '#4ECDC4', bodyShape: 'pear', clawColor: '#55ACEE', clawShape: 'crab', tailColor: '#A8E6CF', tailShape: 'mermaid', eyeStyle: 'sleepy', patternStyle: 'belly', patternColor: '#FFFFFF', diyCanvas: null }
