                                        {/* Seal & Buttons */}
                                        <div className="mt-8 flex justify-between items-end relative">
                                            <div className="w-28 h-28 absolute -bottom-4 -left-4 animate-stamp">
                                                <Icons.Seal />
                                            </div>
                                            
                                            <div className="flex-1"></div>
                                            
                                            <button onClick={() => window.print()} className="px-6 py-4 bg-[#FFE66D] cute-border cute-shadow font-black flex items-center gap-2 cute-btn">
                                                <Icons.Download /> Print / Save
                                            </button>
                                        </div>
                                    </div>

                                </div>
                            </div>
                        )}

                        {/* -------------------- WALL VIEW -------------------- */}
                        {view === 'wall' && (
                            <div className="h-full overflow-y-auto pr-4 animate-[fadeIn_0.5s_ease-out] custom-scrollbar">
                                <div className="text-center mb-12 pt-8">
                                    <h2 className="text-5xl md:text-7xl font-black text-[#FF6B6B] tracking-wide inline-block relative" style={{textShadow: '4px 4px 0px #2C3E50'}}>
                                        The Lobster Wall
                                        <div className="absolute -top-6 -right-12 w-16 h-16 rotate-12">
                                            <svg viewBox="0 0 100 100"><path d="M 50 10 L 60 40 L 90 50 L 60 60 L 50 90 L 40 60 L 10 50 L 40 40 Z" fill="#FFE66D" stroke="#2C3E50" strokeWidth="4"/></svg>
                                        </div>
                                    </h2>
                                    <p className="text-2xl font-bold text-gray-500 mt-4">Happy homes for happy bugs!</p>
                                </div>

                                <div className="masonry-grid max-w-7xl mx-auto pb-12">
                                    {crawfishDB.map((cf, idx) => (
                                        <div key={cf.id + idx} className="masonry-item">
                                            <div 
                                                onClick={() => { setActiveCrawfish(cf); setView('certificate'); }}
                                                className="bg-white p-6 cute-border shadow-[6px_6px_0px_#2C3E50] hover:shadow-[12px_12px_0px_#2C3E50] hover:-translate-y-2 transition-all duration-300 cursor-pointer flex flex-col group relative"
                                            >
                                                {/* ID Tag */}
                                                <div className="absolute top-3 left-3 bg-[#FFF9F0] border-2 border-[#2C3E50] px-2 py-1 rounded-md text-xs font-black z-10">
                                                    #{cf.id}
                                                </div>
                                                
                                                {/* Image Container */}
                                                <div className={`w-full aspect-square bg-opacity-20 rounded-xl mb-4 p-4 transition-transform duration-500 group-hover:scale-105`} style={{ backgroundColor: cf.design.bodyColor }}>
                                                    <CuteCrawfish design={cf.design} />
                                                </div>
                                                
                                                {/* Details */}
                                                <div className="flex-1 flex flex-col">
                                                    <h3 className="text-2xl font-black text-[#2C3E50] leading-tight mb-1 truncate">{cf.name}</h3>
                                                    <p className="text-gray-500 font-bold text-sm mb-3 border-b-2 border-dashed border-gray-200 pb-2">
                                                        Adopted by <span className="text-[#FF6B6B]">{cf.owner}</span>
                                                    </p>
                                                    <div className="flex justify-between items-center mt-auto">
                                                        <span className="bg-[#FFE66D] px-2 py-1 rounded-md text-xs font-bold border-2 border-[#2C3E50] truncate max-w-[60%]">
                                                            {cf.relationship}
                                                        </span>
                                                        <span className="text-gray-400 text-xs font-bold">{cf.date}</span>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    ))}
                                </div>
                            </div>
                        )}

                    </main>
                </div>
            );
        };

        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<App />);
    </script>

</body></html>
